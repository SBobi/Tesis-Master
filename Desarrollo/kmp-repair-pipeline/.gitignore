# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.venv/
venv/

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.secrets/
service-account.json
service-account-*.json
*service-account*.json

# ── Runtime data (entirely regenerated — do NOT commit) ──────────────────────
# data/artifacts/ — shadow workspaces: cloned KMP repos with embedded .git dirs,
#                   execution outputs, LLM prompts/responses, patches, logs.
#                   These are large (GBs) and reproducible from the pipeline.
data/artifacts/*
!data/artifacts/.gitkeep

# data/reports/ — generated CSV/JSON/MD aggregated reports.
#                 Re-run `kmp-repair report --format all` to regenerate.
data/reports/*
!data/reports/.gitkeep

# ── Shadow workspace embedded repos (safety net) ─────────────────────────────
# Workspace clones contain .git dirs which git would treat as submodules.
# The data/artifacts/* rule above covers these, but this is an explicit guard.
data/artifacts/*/workspace/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
