# ── Database (same instance as kmp-repair-pipeline) ───────────────────────
KMP_DATABASE_URL=postgresql+psycopg2://kmp_repair:kmp_repair_dev@localhost:5432/kmp_repair
DATABASE_URL=postgresql://kmp_repair:kmp_repair_dev@localhost:5432/kmp_repair

# ── Redis / RQ ────────────────────────────────────────────────────────────
KMP_REDIS_URL=redis://localhost:6379/0
KMP_RQ_QUEUE=kmp_pipeline
KMP_RQ_DEFAULT_TIMEOUT_S=10800

# ── Web API ───────────────────────────────────────────────────────────────
KMP_WEB_API_HOST=0.0.0.0
KMP_WEB_API_PORT=8000
KMP_WEB_CORS_ORIGINS=http://localhost:3000

# ── Artifacts (absolute path → same store as the CLI pipeline) ─────────────
KMP_ARTIFACT_BASE=/Users/sbobi/Desktop/Tesis-Master/Desarrollo/kmp-repair-pipeline/data/artifacts
KMP_REPORT_OUTPUT_DIR=/Users/sbobi/Desktop/Tesis-Master/Desarrollo/kmp-repair-pipeline/data/reports

# ── LLM provider ──────────────────────────────────────────────────────────
KMP_LLM_PROVIDER=vertex
KMP_LLM_MODEL=gemini-2.5-flash
KMP_VERTEX_PROJECT=tesis-master-492401
KMP_VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/Users/sbobi/Desktop/Tesis-Master/Desarrollo/kmp-repair-pipeline/service-account.json

# ── Java (Gradle worker needs Java 21 LTS) ────────────────────────────────
JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-21.jdk/Contents/Home

# ── Android SDK (explicit env for maintainability) ─────────────────────────
ANDROID_HOME=/Users/sbobi/Library/Android/sdk
ANDROID_SDK_ROOT=/Users/sbobi/Library/Android/sdk
