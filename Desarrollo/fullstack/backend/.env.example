# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kmp_repair:kmp_repair_dev@localhost:5432/kmp_repair

# ── Redis / RQ ────────────────────────────────────────────────────────────
KMP_REDIS_URL=redis://localhost:6379/0
KMP_RQ_QUEUE=kmp_pipeline
KMP_RQ_DEFAULT_TIMEOUT_S=10800

# ── Web API ───────────────────────────────────────────────────────────────
KMP_WEB_API_HOST=0.0.0.0
KMP_WEB_API_PORT=8000
KMP_WEB_CORS_ORIGINS=http://localhost:3000

# ── Artifacts ─────────────────────────────────────────────────────────────
# Must point to the same artifact store used by the canonical pipeline CLI.
# Relative paths resolved from CWD of the backend process.
KMP_ARTIFACT_BASE=../../kmp-repair-pipeline/data/artifacts
KMP_REPORT_OUTPUT_DIR=../../kmp-repair-pipeline/data/reports

# ── LLM Providers (inherited from canonical pipeline .env) ────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project

# ── GitHub (for ingest) ───────────────────────────────────────────────────
GITHUB_TOKEN=your-github-token

# ── Java (macOS worker bootstrap) ────────────────────────────────────────
# JAVA_HOME is auto-detected by the worker on macOS. Override here if needed.
# JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-21.jdk/Contents/Home

# ── Android SDK (recommended explicit config) ─────────────────────────────
# Set both variables to the same SDK path to keep web checks and runners aligned.
# ANDROID_HOME=/Users/your-user/Library/Android/sdk
# ANDROID_SDK_ROOT=/Users/your-user/Library/Android/sdk
